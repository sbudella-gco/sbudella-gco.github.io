diff -uprN src.orig/libexec/rtld-elf/i386/rtld_start.S src/libexec/rtld-elf/i386/rtld_start.S
--- src.orig/libexec/rtld-elf/i386/rtld_start.S	2009-02-08 19:09:36.000000000 +0100
+++ src/libexec/rtld-elf/i386/rtld_start.S	2009-10-04 15:47:44.000000000 +0200
@@ -25,6 +25,19 @@
  * $FreeBSD: src/libexec/rtld-elf/i386/rtld_start.S,v 1.4 2005/05/19 07:32:42 dfr Exp $
  */
 
+	.data
+	.align	4
+/*
+ * rtld is not built with crt1.o, so we need to provide a rtld specific
+ * syscall trampoline, whose entry point symbol has to be necessarily
+ * absolute (its address is the top of the user stack), because rtld accesses
+ * the trampoline very early, even before it has been relocated.
+ */
+	.weak	sctramp_entry
+	.type	sctramp_entry, @object
+sctramp_entry:
+	.long	0
+
 	.text
 	.align	4
 	.globl	.rtld_start
@@ -39,6 +52,8 @@
 	movl	%esp,%ecx		# construct address of obj_main
 	addl	$4,%ecx
 	subl	$4,%esp			# Keep stack aligned
+	jmp	.sctf			# Get the rtld syscall trampoline
+.sctb:	popl	sctramp_entry		# using the old good jmp/call trick
 	pushl	%ecx			# Pass address of obj_main
 	pushl	%ebx			# Pass address of exit proc
 	pushl	%eax			# Pass initial stack pointer to rtld
@@ -89,3 +104,14 @@ _rtld_bind_start:
 	popf				# Restore eflags
 	leal	4(%esp),%esp		# Discard reloff, do not change eflags
 	ret				# "Return" to target address
+
+/* Use the old int $0x80 instruction for rtld's syscall trampoline. */
+	.align	4, 0x90
+	.weak	sctramp_rtld
+	.type	sctramp_rtld, @function
+.sctf:	call	.sctb
+sctramp_rtld:
+	popl	%ecx
+	int	$0x80
+	pushl	%ecx
+	ret
