+	spage = vm_spage_alloc(p, PAGE_SIZE, SPAGE_GENERIC, TRUE);
+	if (vdso_setup(VDSO_NSYM, vdso_generic_symv, &vdso_generic_start,
+	    vdso_generic_size, p, (caddr_t) spage->addr) != 0)
+		panic("exec_new_vmspace: unable to set vdso up");
+
 	return (0);
 }
 
